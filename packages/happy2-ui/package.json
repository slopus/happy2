{
    "name": "happy2-ui",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./styles.css": "./src/styles.css",
        "./testing": "./src/testing/index.ts"
    },
    "scripts": {
        "dev": "vite --host 127.0.0.1",
        "build": "vite build",
        "test": "node ../../scripts/run-ui-alignment-tests.mjs",
        "test:artifacts": "VITE_HAPPY2_WRITE_SCREENSHOTS=1 node ../../scripts/run-ui-alignment-tests.mjs",
        "test:watch": "playwright install chromium firefox webkit && vitest",
        "typecheck": "tsc --project tsconfig.json",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "node --test eslint/*.test.mjs && eslint . && oxlint .",
        "lint:fix": "eslint . --fix && oxlint . --fix",
        "clean": "rm -rf dist coverage"
    },
    "dependencies": {
        "@blocknote/core": "^0.51.4",
        "@blocknote/mantine": "^0.51.4",
        "@blocknote/react": "^0.51.4",
        "@fontsource-variable/figtree": "^5.2.10",
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@mantine/core": "^9.4.1",
        "@mantine/hooks": "^9.4.1",
        "@tanstack/react-virtual": "^3.14.6",
        "happy2-state": "workspace:*",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "thumbhash": "^0.1.1",
        "y-protocols": "^1.0.7",
        "yjs": "^13.6.31",
        "zustand": "5.0.14"
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@babel/eslint-parser": "^8.0.1",
        "@eslint/js": "^9.39.2",
        "@tailwindcss/vite": "^4.3.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/browser-playwright": "^4.1.10",
        "eslint": "^9.39.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.7.0",
        "happy2-gym": "workspace:*",
        "playwright": "^1.61.1",
        "tailwindcss": "^4.3.2",
        "typescript": "^7.0.2",
        "vite": "^8.1.4",
        "vitest": "^4.1.10"
    }
}
