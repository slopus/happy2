{
    "name": "happy2-app",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "build": "vite build",
        "test": "vitest run",
        "test:gym": "node ../../scripts/run-ui-alignment-tests.mjs --config vite.gym.config.ts",
        "test:watch": "vitest",
        "typecheck": "tsc --project tsconfig.json",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "eslint . && oxlint .",
        "lint:fix": "eslint . --fix && oxlint . --fix",
        "clean": "rm -rf dist coverage"
    },
    "dependencies": {
        "@slopus/ghostty-wasm": "1.3.4",
        "@slopus/ghostty-web": "0.1.0",
        "@tanstack/react-router": "^1.170.18",
        "happy2-state": "workspace:*",
        "happy2-ui": "workspace:*",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "thumbhash": "^0.1.1"
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@babel/eslint-parser": "^8.0.1",
        "@eslint/js": "^9.39.2",
        "@tailwindcss/vite": "^4.3.2",
        "@tanstack/eslint-plugin-router": "^1.162.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/browser-playwright": "^4.1.10",
        "eslint": "^9.39.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.7.0",
        "happy2-gym": "workspace:*",
        "jsdom": "^29.1.1",
        "playwright": "^1.61.1",
        "tailwindcss": "^4.3.2",
        "typescript": "^7.0.2",
        "vite": "^8.1.4",
        "vitest": "^4.1.10"
    }
}
