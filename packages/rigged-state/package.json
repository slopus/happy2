{
    "name": "rigged-state",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./testing": "./src/testing/index.ts"
    },
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --project tsconfig.json",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "clean": "rm -rf coverage"
    },
    "devDependencies": {
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    }
}
