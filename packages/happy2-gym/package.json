{
    "name": "happy2-gym",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./sources/index.ts",
        "./playwright": "./sources/playwright/index.ts",
        "./rig": "./sources/rig/index.ts",
        "./state": "./sources/state/index.ts"
    },
    "scripts": {
        "test": "pnpm test:server && pnpm test:playwright",
        "test:playwright": "node ../../scripts/run-ui-alignment-tests.mjs --config vitest.playwright.config.ts",
        "test:playwright:artifacts": "VITE_HAPPY2_WRITE_SCREENSHOTS=1 node ../../scripts/run-ui-alignment-tests.mjs --config vitest.playwright.config.ts",
        "test:server": "vitest run",
        "test:server:coverage": "vitest run --config vitest.coverage.config.ts --coverage",
        "test:watch": "vitest",
        "typecheck": "tsc --project tsconfig.json",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "clean": "rm -rf coverage"
    },
    "dependencies": {
        "@libsql/client": "^0.17.4",
        "fastify": "^5.8.2",
        "happy2-server": "workspace:*",
        "happy2-state": "workspace:*"
    },
    "devDependencies": {
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@slopus/ghostty-web": "0.1.0",
        "@types/node": "^26.1.1",
        "@types/ws": "^8.18.1",
        "@types/yazl": "^3.3.1",
        "@vitest/browser-playwright": "^4.1.10",
        "@vitest/coverage-v8": "^4.1.10",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.73.0",
        "playwright": "^1.61.1",
        "sharp": "^0.35.3",
        "typescript": "^7.0.2",
        "vite": "^8.1.4",
        "vitest": "^4.1.10",
        "ws": "^8.21.1",
        "yazl": "^3.3.1",
        "yjs": "^13.6.31"
    },
    "engines": {
        "node": ">=22.16.0"
    }
}
