{
    "name": "happy2-plugin-sdk",
    "version": "0.1.0",
    "private": true,
    "bin": {
        "happy2-plugin-build": "./src/build/cli.ts"
    },
    "type": "module",
    "exports": {
        "./server": "./src/server/index.ts",
        "./app": "./src/app/index.ts",
        "./build": "./src/build/index.ts"
    },
    "scripts": {
        "build": "tsc --project tsconfig.json --noEmit",
        "test": "vitest run",
        "typecheck": "tsc --project tsconfig.json",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "clean": "rm -rf dist .happy2-build"
    },
    "dependencies": {
        "@modelcontextprotocol/ext-apps": "^1.7.4",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@vitejs/plugin-react": "^6.0.3",
        "react": "^19.2.7",
        "sharp": "^0.35.3",
        "vite": "^8.1.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.14",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.73.0",
        "tsx": "^4.23.0",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
