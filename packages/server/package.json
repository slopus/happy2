{
    "name": "@slopus/rigged",
    "version": "0.1.0",
    "description": "Rigged web app, server, and authentication service",
    "bin": {
        "rigged": "bin/rigged.js",
        "rigged-server": "bin/rigged-server.js"
    },
    "files": [
        "bin",
        "dist",
        "drizzle",
        "rigged.example.toml",
        "README.md",
        "Dockerfile"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "tsx watch sources/cli.ts",
        "build": "pnpm run build:server && VITE_RIGGED_SERVER_URL='' pnpm --filter @rigged/web exec vite build --outDir ../server/dist/web --emptyOutDir false",
        "build:server": "rm -rf dist && tsc --project tsconfig.json",
        "start": "node dist/runner.js",
        "start:server": "node dist/cli.js",
        "prepack": "pnpm run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "clean": "rm -rf dist coverage"
    },
    "dependencies": {
        "@fastify/cors": "^11.3.0",
        "@fastify/http-proxy": "^11.5.0",
        "@fastify/multipart": "^10.1.0",
        "@fastify/static": "^10.1.0",
        "@libsql/client": "^0.17.4",
        "@paralleldrive/cuid2": "^3.3.0",
        "@slopus/rig": "^0.0.9",
        "drizzle-orm": "^0.45.2",
        "fastify": "^5.8.2",
        "jose": "^6.1.3",
        "nodemailer": "^7.0.13",
        "sharp": "^0.35.3",
        "smol-toml": "^1.4.2",
        "thumbhash": "^0.1.1"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@types/nodemailer": "^7.0.4",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.73.0",
        "tsx": "^4.21.0",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    },
    "engines": {
        "node": ">=22.16.0"
    }
}
