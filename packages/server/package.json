{
    "name": "@slopus/rigged",
    "version": "0.1.0",
    "description": "Rigged server and authentication service",
    "bin": {
        "rigged-server": "./dist/cli.js"
    },
    "files": [
        "dist",
        "drizzle",
        "rigged.example.toml",
        "README.md",
        "Dockerfile"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "dev": "tsx watch sources/cli.ts",
        "build": "rm -rf dist && tsc --project tsconfig.json",
        "start": "node dist/cli.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "clean": "rm -rf dist coverage"
    },
    "dependencies": {
        "@fastify/cors": "^11.3.0",
        "@fastify/multipart": "^10.1.0",
        "@libsql/client": "^0.17.4",
        "@paralleldrive/cuid2": "^3.3.0",
        "drizzle-orm": "^0.45.2",
        "fastify": "^5.8.2",
        "jose": "^6.1.3",
        "nodemailer": "^7.0.13",
        "sharp": "^0.35.3",
        "smol-toml": "^1.4.2",
        "thumbhash": "^0.1.1"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@types/nodemailer": "^7.0.4",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.73.0",
        "tsx": "^4.21.0",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    },
    "engines": {
        "node": ">=22.16.0"
    }
}
