{
    "name": "happy2-server",
    "version": "0.0.3",
    "description": "Happy (2) server and authentication service",
    "bin": {
        "happy2-server": "bin/happy2-server.js"
    },
    "files": [
        "bin/happy2-server.js",
        "dist",
        "drizzle",
        "happy2.example.toml",
        "README.md",
        "PLUGINS.md"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "predev": "pnpm --dir ../.. plugins:prepare",
        "dev": "tsx watch sources/cli.ts",
        "build": "pnpm run build:server",
        "build:server": "rm -rf dist && tsc --project tsconfig.json && cp sources/routes/portShareErrorPage.html dist/routes/portShareErrorPage.html && pnpm run plugins:assemble",
        "plugins:assemble": "tsx tooling/plugin-catalog/cli.ts",
        "start": "node dist/cli.js",
        "start:server": "node dist/cli.js",
        "prepack": "pnpm --dir ../.. plugins:build && pnpm run build:server",
        "pretest": "pnpm --dir ../.. plugins:prepare",
        "test": "vitest run",
        "test:coverage-tooling": "vitest run --config tooling/server-coverage/vitest.config.ts",
        "architecture:check": "tsx tooling/server-architecture/cli.ts",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.tooling.json",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "clean": "rm -rf dist coverage"
    },
    "dependencies": {
        "@fastify/cors": "^11.3.0",
        "@fastify/http-proxy": "^11.5.0",
        "@fastify/multipart": "^10.1.0",
        "@fastify/static": "^10.1.0",
        "@libsql/client": "^0.17.4",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@paralleldrive/cuid2": "^3.3.0",
        "@slopus/rig": "^0.0.33",
        "drizzle-orm": "^0.45.2",
        "fastify": "^5.8.2",
        "jose": "^6.1.3",
        "nodemailer": "^7.0.13",
        "pino": "^10.3.1",
        "sharp": "^0.35.3",
        "smol-toml": "^1.4.2",
        "thumbhash": "^0.1.1",
        "ws": "^8.21.1",
        "yaml": "^2.9.0",
        "yjs": "^13.6.31"
    },
    "devDependencies": {
        "@babel/parser": "^7.29.7",
        "@babel/types": "^7.29.7",
        "@types/istanbul-lib-coverage": "^2.0.6",
        "@types/istanbul-lib-report": "^3.0.3",
        "@types/istanbul-reports": "^3.0.4",
        "@types/node": "^26.1.1",
        "@types/nodemailer": "^7.0.4",
        "@types/ws": "^8.18.1",
        "@vitest/coverage-v8": "^4.1.10",
        "happy2-plugin-chat-management": "workspace:*",
        "happy2-plugin-documents": "workspace:*",
        "happy2-plugin-environment-management": "workspace:*",
        "happy2-plugin-hello": "workspace:*",
        "happy2-plugin-movie-catalog": "workspace:*",
        "happy2-plugin-plugin-developer": "workspace:*",
        "happy2-plugin-port-sharing": "workspace:*",
        "happy2-plugin-todos": "workspace:*",
        "istanbul-lib-coverage": "^3.2.2",
        "istanbul-lib-report": "^3.0.1",
        "istanbul-reports": "^3.2.0",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.73.0",
        "tsx": "^4.21.0",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    },
    "engines": {
        "node": ">=22.16.0"
    }
}
